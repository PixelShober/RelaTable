# --- RelaTable environment ---
# Local debugging runs natively (no Docker) against a local SQLite file.

# SQLite database location (Prisma). Path is relative to prisma/schema.prisma,
# so ../data puts the DB in the project-root data/ dir alongside uploads.
DATABASE_URL="file:../data/relatable.db"

# Directory for profile-image uploads + backups. Created on first write.
DATA_DIR="./data"

# Session cookie name + lifetime (days) for "remember me".
SESSION_COOKIE="relatable_session"
SESSION_TTL_DAYS_REMEMBER="30"
SESSION_TTL_HOURS_SHORT="12"

# Map provider: "leaflet" (keyless OSM, default) or "google".
PUBLIC_MAP_PROVIDER="leaflet"
# Only needed when PUBLIC_MAP_PROVIDER=google
PUBLIC_GOOGLE_MAPS_API_KEY=""

# Notion one-time import (used only by `npm run import:notion`).
NOTION_TOKEN=""

# MCP-Server (Remote, /api/mcp): Bearer-Token für den Streamable-HTTP-Endpunkt.
# Fail-closed: ist der Wert leer, antwortet der MCP-Server mit 503 (deaktiviert).
# Erzeuge ein langes Token, z. B.: openssl rand -hex 32
RELATABLE_MCP_TOKEN=""

# In-App-Erzählung (Mikrofon → KI → Graph). Nutzt die MCP-Tools intern, daher
# muss RELATABLE_MCP_TOKEN gesetzt sein. OpenRouter: ein Key, beliebiges Modell.
# Key: https://openrouter.ai/keys  · Modell-Slugs: https://openrouter.ai/models
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"
