{
  "name": "relatable",
  "version": "1.0.0",
  "description": "RelaTable — private, self-hosted relationship graph for a single owner.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "import:notion": "tsx scripts/import-notion.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:narrate:claude": "vite-node scripts/narrate-claude-smoke.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.4",
    "@types/node": "^22.9.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "svelte": "^5.2.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.1.0",
    "cytoscape": "^3.30.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "zod": "^3.23.8"
  }
}
